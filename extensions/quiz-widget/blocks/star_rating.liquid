<!-- Quizora Widget Container (Shopify Integration) -->
<div class="quizora-wrapper-{{ block.id }}" style="margin: 20px 0; display: flex; justify-content: center;">
  
  {% if block.settings.display_mode == 'popup' %}
    <!-- Replicating the design from test-live-production.html -->
    <button 
      data-quiz-trigger="{{ block.id }}"
      class="quizora-launch-btn"
      style="
        padding: 18px 40px;
        background: {{ block.settings.button_color }};
        color: {{ block.settings.button_text_color }};
        border: none;
        border-radius: 16px;
        cursor: pointer;
        font-weight: 800;
        font-size: 1.1rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        transition: all 0.3s;
      "
      onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 15px 40px rgba(0,0,0,0.2)';"
      onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 30px rgba(0,0,0,0.1)';"
    >
      {{ block.settings.button_label }}
    </button>
  {% endif %}

  <!-- The Script that makes it all work -->
  <script
    type="module"
    src="https://quizora-server.vercel.app/assets/widget.js"
    data-quiz-id="{{ block.settings.quiz_id | strip }}"
    data-server-url="https://quizora-server.vercel.app"
    data-shop="{{ shop.permanent_domain }}"
    data-trigger="[data-quiz-trigger='{{ block.id }}']"
    data-layout="{% if block.settings.display_mode == 'embed' %}inline{% else %}modal{% endif %}"
    {% if block.settings.display_mode == 'embed' %}data-open="true"{% endif %}
  ></script>
</div>


{% schema %}
{
  "name": "Quizora Quiz",
  "target": "section",
  "settings": [
    { 
      "type": "text", 
      "id": "quiz_id", 
      "label": "Enter Quiz ID", 
      "default": "default-quiz" 
    },
    {
      "type": "select",
      "id": "display_mode",
      "label": "Display Mode",
      "options": [
        { "value": "embed", "label": "Embed directly in page" },
        { "value": "popup", "label": "Open as Popup (Via Button)" }
      ],
      "default": "popup"
    },
    {
      "type": "header",
      "content": "Button Settings (For Popup Mode)"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Text",
      "default": "Take the Quiz!"
    },
    { 
      "type": "color", 
      "id": "button_color", 
      "label": "Button Color", 
      "default": "#3b82f6" 
    },
    { 
      "type": "color", 
      "id": "button_text_color", 
      "label": "Button Text Color", 
      "default": "#ffffff" 
    },
    {
      "type": "header",
      "content": "Aesthetics"
    },
    { 
      "type": "color", 
      "id": "bg_color", 
      "label": "Background Color", 
      "default": "#0a0a0b" 
    }
  ]
}
{% endschema %}
